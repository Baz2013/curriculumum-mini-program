/**app.wxss**/
/* 全局样式 */

page {
  font-family: -apple-system-font, Helvetica Neue, Helvetica, sans-serif;
  color: #333;
  background-color: #f5f5f5;
}

.container {
  height: 100%;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 卡片样式 */
.card {
  background: white;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.08);
  margin: 24rpx;
  overflow: hidden;
}

.card-header {
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.card-body {
  padding: 30rpx;
}

.card-footer {
  padding: 20rpx 30rpx;
  background: #fafafa;
  border-top: 1rpx solid #eee;
}

/* 标题样式 */
.title-lg {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.title-md {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.title-sm {
  font-size: 28rpx;
  font-weight: 500;
  color: #666;
}

.text-primary {
  color: #1890ff;
}

.text-success {
  color: #52c41a;
}

.text-warning {
  color: #faad14;
}

.text-danger {
  color: #ff4d4f;
}

.text-gray {
  color: #999;
}

/* 按钮样式 */
.btn {
  width: 120rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 8rpx;
  font-size: 28rpx;
  transition: opacity 0.3s;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(to right, #1890ff, #096dd9);
  color: white;
}

.btn-default {
  background: #fff;
  color: #333;
  border: 1rpx solid #ddd;
}

.btn-block {
  width: 100%;
}

.btn-large {
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
}

/* 输入框样式 */
.input-group {
  margin-bottom: 30rpx;
}

.input-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.input-field {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
}

/* 徽章样式 */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
  color: white;
}

.badge-primary {
  background: #1890ff;
}

.badge-success {
  background: #52c41a;
}

.badge-warning {
  background: #faad14;
}

.badge-danger {
  background: #ff4d4f;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #eee;
  margin: 30rpx 0;
}

/* Flex布局 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.justify-between {
  justify-content: space-between;
}

.align-center {
  align-items: center;
}

.space-around {
  justify-content: space-around;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}

.no-data {
  text-align: center;
  padding: 100rpx 0;
  color: #ccc;
}

.no-data-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.no-data-text {
  font-size: 28rpx;
}