/* login.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
}

.header {
  text-align: center;
  margin-bottom: 100rpx;
}

.logo {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 16rpx;
}

.welcome-text {
  display: block;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
}

.login-methods {
  flex: 1;
}

.btn-login {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.btn-login::after {
  border: none;
}

.btn-weixin {
  background: #07c160;
  color: white;
}

.btn-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.btn-text {
  flex: 1;
}

.btn-hover {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.2);
}

.divider {
  display: flex;
  align-items: center;
  margin: 48rpx 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.3);
}

.divider-text {
  padding: 0 24rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.share-code-input {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.input-code {
  flex: 1;
  height: 88rpx;
  background: white;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  text-align: center;
}

.btn-confirm {
  width: 160rpx;
  height: 88rpx;
  background: white;
  color: #667eea;
  border-radius: 16rpx;
  border: none;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-confirm::after {
  border: none;
}

.btn-confirm[disabled] {
  opacity: 0.5;
}

.tips {
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10rpx);
  border-radius: 16rpx;
  padding: 24rpx;
}

.tip-text {
  font-size: 28rpx;
  color: white;
  font-weight: bold;
}

.tip-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
  margin-top: 8rpx;
}

.footer {
  text-align: center;
  padding: 40rpx 0;
}

.footer-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-right: 8rpx;
}

.link-register {
  font-size: 28rpx;
  color: white;
  font-weight: bold;
  text-decoration: underline;
}