/* login.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
}

.header {
  text-align: center;
  margin-bottom: 100rpx;
}

.logo {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 16rpx;
}

.welcome-text {
  display: block;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
}

.login-methods {
  flex: 1;
}

.btn-login {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.btn-login::after {
  border: none;
}

.btn-weixin {
  background: #07c160;
  color: white;
}

.btn-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.btn-text {
  flex: 1;
}

.btn-hover {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.2);
}

.divider {
  display: flex;
  align-items: center;
  margin: 48rpx 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.3);
}

.divider-text {
  padding: 0 24rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.share-code-input {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.input-code {
  flex: 1;
  height: 88rpx;
  background: white;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  text-align: center;
}

.btn-confirm {
  width: 160rpx;
  height: 88rpx;
  background: white;
  color: #667eea;
  border-radius: 16rpx;
  border: none;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-confirm::after {
  border: none;
}

.btn-confirm[disabled] {
  opacity: 0.5;
}

.tips {
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10rpx);
  border-radius: 16rpx;
  padding: 24rpx;
}

.tip-text {
  font-size: 28rpx;
  color: white;
  font-weight: bold;
}

.tip-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
  margin-top: 8rpx;
}

.footer {
  text-align: center;
  padding: 40rpx 0;
}

.footer-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-right: 8rpx;
}

.link-register {
  font-size: 28rpx;
  color: white;
  font-weight: bold;
  text-decoration: underline;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

.features {
  margin-top: 48rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 20rpx;
}

.feature-icon {
  font-size: 32rpx;
  color: #fff;
  margin-right: 16rpx;
  font-weight: bold;
}

.feature-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.agreement {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* ==================== 待审批状态卡片样式 ==================== */

.waiting-card {
  background: white;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.2);
  animation: slideUp 0.4s ease-out;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.card-header {
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%);
  padding: 32rpx;
  text-align: center;
}

.status-badge {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 32rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: bold;
  transition: all 0.3s ease;
}

.badge-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.6;
    transform: scale(1.2);
  }
}

.badge-text {
  font-size: 28rpx;
}

.status-badge.pending {
  background: #fef3c7;
  color: #d97706;
}

.status-badge.pending .badge-dot {
  background: #fbbf24;
}

.status-badge.unknown {
  background: #fee2e2;
  color: #dc2626;
}

.status-badge.unknown .badge-dot {
  background: #ef4444;
}

.card-body {
  padding: 48rpx 40rpx;
}

.user-avatar-wrapper {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.user-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid #f3f4f6;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.user-info {
  text-align: center;
  margin-bottom: 32rpx;
}

.nickname {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.account-id {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
}

.status-message {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: #eff6ff;
  border-radius: 16rpx;
  margin-bottom: 32rpx;
}

.status-message .icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.status-message .text {
  font-size: 28rpx;
  color: #1e40af;
  font-weight: 600;
}

.tips-box {
  background: #fafafa;
  border-left: 4rpx solid #3b82f6;
  padding: 24rpx;
  border-radius: 8rpx;
}

.tip-title {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #374151;
  margin-bottom: 16rpx;
}

.tip-item {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.8;
  margin-bottom: 8rpx;
}

.card-footer {
  padding: 32rpx 40rpx;
  background: #f9fafb;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  border: none;
  font-size: 30rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.3);
}

.action-btn.primary:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 28rpx rgba(102, 126, 234, 0.4);
}

.action-btn.secondary {
  background: white;
  color: #6b7280;
  border: 2rpx solid #e5e7eb;
}

.action-btn.secondary:hover {
  background: #f9fafb;
  border-color: #d1d5db;
}

.contact-support {
  text-align: center;
  padding: 32rpx 0;
}

.support-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}