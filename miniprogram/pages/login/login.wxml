<!-- login.wxml -->
<view class="container">
  <view class="header">
    <view class="logo">📚</view>
    <text class="title">课程预约平台</text>
    <text class="subtitle">一键登录，即刻开始学习之旅</text>
  </view>

  <view class="login-area">
    <button
      class="btn-login btn-weixin"
      open-type="getUserInfo"
      bindgetuserinfo="onGetUserInfo"
      hover-class="btn-hover"
    >
      <text class="btn-icon">💬</text>
      <text class="btn-text">微信快捷登录</text>
    </button>

    <view class="features">
      <view class="feature-item">
        <text class="feature-icon">✓</text>
        <text class="feature-text">免注册，一步到位</text>
      </view>
      <view class="feature-item">
        <text class="feature-icon">✓</text>
        <text class="feature-text">海量优质课程任选</text>
      </view>
      <view class="feature-item">
        <text class="feature-icon">✓</text>
        <text class="feature-text">智能匹配个性化推荐</text>
      </view>
    </view>
  </view>

  <view class="footer">
    <text class="agreement">登录即表示同意《用户协议》和《隐私政策》</text>
  </view>
</view>