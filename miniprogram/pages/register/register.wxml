<!-- register.wxml -->
<view class="container">
  <view class="header">
    <view class="logo">📚</view>
    <text class="title">欢迎加入</text>
    <text class="subtitle">课程预约平台</text>
  </view>

  <form bindsubmit="handleRegister">
    <view class="form-group">
      <label class="label">昵称 *</label>
      <input 
        class="input" 
        placeholder="请输入您的昵称" 
        maxlength="20"
        value="{{formData.nickname}}"
        bindinput="onNicknameInput"
      />
    </view>

    <view class="form-group">
      <label class="label">手机号</label>
      <input 
        class="input" 
        type="number"
        placeholder="请输入手机号（选填）" 
        maxlength="11"
        value="{{formData.phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <view class="form-group">
      <label class="label">邮箱</label>
      <input 
        class="input" 
        type="text"
        placeholder="请输入邮箱（选填）" 
        value="{{formData.email}}"
        bindinput="onEmailInput"
      />
    </view>

    <view class="form-group">
      <label class="label">申请理由</label>
      <textarea 
        class="textarea" 
        placeholder="简要介绍您的学习目标和期望..."
        maxlength="200"
        value="{{formData.reason}}"
        bindinput="onReasonInput"
        autoHeight
      ></textarea>
      <text class="char-count">{{formData.reason.length}}/200</text>
    </view>

    <view class="info-box">
      <text class="info-icon">ℹ️</text>
      <text class="info-text">提交申请后，需要等待管理员审核通过后方可使用</text>
    </view>

    <button 
      class="btn-submit" 
      form-type="submit" 
      disabled="{{submitting}}"
      hover-class="btn-hover"
    >
      {{submitting ? '提交中...' : '提交申请'}}
    </button>
  </form>

  <view class="footer-links">
    <text class="link" bindtap="goToLogin">已有账号？去登录</text>
  </view>
</view>