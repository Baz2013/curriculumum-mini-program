/* register.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx;
}

.header {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.form-group {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 80rpx;
  font-size: 30rpx;
  color: #333;
  border: none;
  outline: none;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  font-size: 30rpx;
  color: #333;
  border: none;
  outline: none;
  resize: none;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

.info-box {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.info-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.info-text {
  flex: 1;
  font-size: 26rpx;
  color: white;
  line-height: 1.6;
}

.btn-submit {
  width: 100%;
  height: 96rpx;
  background: white;
  color: #667eea;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.btn-submit::after {
  border: none;
}

.btn-submit.disabled {
  opacity: 0.6;
}

.btn-hover {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.2);
}

.footer-links {
  text-align: center;
}

.link {
  font-size: 28rpx;
  color: white;
  text-decoration: underline;
}