/* my-bookings.wxss */

/* Tab容器 */
.tabs-container {
  position: sticky;
  top: 0;
  z-index: 100;
  background: white;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tabs-wrapper {
  display: flex;
  padding: 0 24rpx;
}

.tab-item {
  position: relative;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s ease;
}

.tab-item.active {
  color: #1890ff;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #1890ff;
  border-radius: 2rpx;
}

.badge-count {
  margin-left: 8rpx;
  padding: 2rpx 10rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 28rpx;
  text-align: center;
  background: #ff4d4f;
  color: white;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: normal;
}

/* 预约列表 */
.bookings-list {
  padding: 24rpx;
  min-height: calc(100vh - 160rpx);
}

.booking-card {
  margin-bottom: 24rpx;
  overflow: visible;
}

.booking-status {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.dot-blue {
  background: #1890ff;
  animation: pulse 2s infinite;
}

.dot-green {
  background: #52c41a;
}

.dot-red {
  background: #ff4d4f;
}

@keyframes pulse {
  0% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
  100% {
    opacity: 1;
  }
}

.status-text {
  font-size: 26rpx;
  color: #666;
}

.booking-main {
  padding: 24rpx;
  background: #fafafa;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.course-basic {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.course-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
  margin-right: 16rpx;
}

.course-category {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  background: #e6f7ff;
  color: #1890ff;
  border-radius: 4rpx;
  font-size: 22rpx;
}

.booking-details {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detail-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
}

.detail-icon {
  font-size: 28rpx;
  width: 32rpx;
  text-align: center;
}

.detail-text {
  color: #666;
  flex: 1;
}

.booking-actions {
  display: flex;
  justify-content: flex-end;
  padding: 0 24rpx 24rpx;
}

.btn-cancel {
  padding: 0 32rpx;
  height: 64rpx;
  line-height: 62rpx;
  background: white;
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
  border-radius: 32rpx;
  font-size: 26rpx;
}

.btn-cancel::after {
  border: none;
}

.btn-cancel:active {
  background: #fff1f0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.explore-link {
  padding: 16rpx 48rpx;
  background: linear-gradient(to right, #1890ff, #096dd9);
  color: white;
  border-radius: 48rpx;
  font-size: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.3);
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 26rpx;
}