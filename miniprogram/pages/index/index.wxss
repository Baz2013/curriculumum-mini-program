/* index.wxss */

.search-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  background: white;
  padding: 20rpx 24rpx;
  display: flex;
  gap: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.search-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.search-btn {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 32rpx;
  background: linear-gradient(to right, #1890ff, #096dd9);
  color: white;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.search-btn::after {
  border: none;
}

/* 分类滚动区域 */
.category-scroll {
  background: white;
  padding: 20rpx 0;
  white-space: nowrap;
}

.category-list {
  display: flex;
  padding: 0 24rpx;
}

.category-item {
  flex-shrink: 0;
  padding: 12rpx 32rpx;
  margin-right: 16rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s ease;
}

.category-item.active {
  background: linear-gradient(to right, #1890ff, #096dd9);
  color: white;
  transform: scale(1.05);
}

/* 课程卡片 */
.course-list {
  padding: 24rpx;
}

.course-card {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
  cursor: pointer;
  transition: transform 0.3s ease;
}

.course-card:active {
  transform: scale(0.98);
}

.course-image {
  width: 100%;
  height: 320rpx;
  object-fit: cover;
  border-radius: 12rpx 12rpx 0 0;
}

.course-info {
  padding: 24rpx;
}

.course-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.course-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.meta-tag {
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
}

.meta-time {
  font-size: 24rpx;
  color: #999;
}

.course-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.course-stats {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx dashed #eee;
}

.stat-item {
  font-size: 24rpx;
  color: #888;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.icon {
  font-size: 28rpx;
}

/* 占位图样式 */
.course-placeholder {
  width: 100%;
  height: 240rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 48rpx;
  border-radius: 12rpx 12rpx 0 0;
}