/* profile.wxss */

.user-header {
  display: flex;
  align-items: center;
  padding: 48rpx 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.avatar-wrapper {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 24rpx;
  background: white;
}

.avatar {
  width: 100%;
  height: 100%;
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.join-date {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 统计数据 */
.stats-section {
  margin-top: -40rpx;
  position: relative;
  z-index: 10;
  border-radius: 24rpx 24rpx 0 0;
}

.stats-grid {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 40rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-number {
  font-size: 48rpx;
  font-weight: bold;
  color: #1890ff;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #eee;
}

/* 菜单区块 */
.menu-section,
.settings-section {
  margin-top: 24rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background 0.3s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #fafafa;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.menu-icon {
  font-size: 40rpx;
  width: 48rpx;
  text-align: center;
}

.menu-title {
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 48rpx;
  color: #ccc;
  font-weight: 300;
}

.menu-badge {
  padding: 4rpx 12rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 24rpx;
  text-align: center;
  background: #ff4d4f;
  color: white;
  border-radius: 16rpx;
  font-size: 20rpx;
  margin-right: 8rpx;
}

.cache-size {
  font-size: 26rpx;
  color: #999;
  margin-right: 8rpx;
}

.menu-switch {
  margin-right: 8rpx;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 48rpx 0;
  color: #ccc;
  font-size: 24rpx;
}